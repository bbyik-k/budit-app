# Supabase 프로젝트 URL (anon public)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (anon) key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key — 서버 전용, seed 스크립트 및 admin 클라이언트에서 사용
SUPABASE_SERVICE_ROLE_KEY=

# (선택) 배포 URL override — Vercel 기본 도메인 외 커스텀 도메인 사용 시 지정
# NEXT_PUBLIC_SITE_URL=https://budit.vercel.app
